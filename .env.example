# Zendesk API credentials (required)
ZENDESK_SUBDOMAIN=your-subdomain
ZENDESK_EMAIL=agent@example.com
ZENDESK_API_TOKEN=your_api_token_here

# Set to true to only report matches without deleting (default: false)
DRY_RUN=false

# Cron expression for scheduled runs (default: hourly at minute 0)
# Examples: "0 * * * *" = hourly, "0 */2 * * *" = every 2 hours, "*/30 * * * *" = every 30 min
CRON_SCHEDULE=0 * * * *

# For Vercel: Secret to authenticate cron requests. Generate with: openssl rand -hex 32
# If set, cron invocations must include Authorization: Bearer <CRON_SECRET>
CRON_SECRET=
