{
  "name": "zendesk-password-reset-cleaner",
  "version": "1.0.0",
  "description": "Agent that identifies and deletes password reset tickets from Zendesk",
  "engines": {
    "node": "20.x"
  },
  "main": "src/index.js",
  "scripts": {
